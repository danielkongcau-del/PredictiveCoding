{
  "phase": "post_incremental_bridge_exploratory",
  "stage": "ef_core_probe",
  "dataset": {
    "dataset_name": "digits",
    "train_fraction": 0.7,
    "val_fraction": 0.15,
    "test_fraction": 0.15,
    "data_seed": 1
  },
  "model": {
    "layer_dims": [
      64,
      16,
      10
    ],
    "hidden_activation": "tanh",
    "output_activation": "identity",
    "weight_scale": 0.05,
    "sigma2": 1.0,
    "eta_x": 0.1,
    "eta_w": 0.02,
    "eta_b": 0.02,
    "eval_steps": 15,
    "state_init": "forward"
  },
  "transport": {
    "teacher_free": true,
    "uses_teacher_artifacts": false,
    "transport_family": "residual_meanflow_core",
    "residual_identity_mode": "residual_corrected_meanflow",
    "energy_substrate": "baseline_pc_energy",
    "local_flow_definition": "exact_negative_hidden_state_gradient",
    "direct_anchor_source": "self_bootstrap_local_field",
    "psi_family": "residual_local_flow_mlp",
    "velocity_parameterization": "u_psi = g_theta + residual_mlp(z_t, target_onehot, t, r)",
    "u_psi_input_contract": "concat([z_t, target_onehot, t, r])",
    "residual_branch_structure": "single_branch",
    "m_traj_input_contract": "concat([z_t, target_onehot, t, r])",
    "m_state_input_contract": null,
    "bootstrap_target_contract": "m_boot = ((Phi_LF_r(z_t; c) - z_t) / r) - g_t",
    "residual_identity_target_contract": "m_id = r * D_T g_t + r * D_T m_psi",
    "identity_loss_weight": 0.1,
    "tangent_epsilon": 0.001,
    "lambda_id_warmup_epochs": 3,
    "lambda_id_ramp_epochs": 3,
    "no_teacher_dependency_in_target_construction": true,
    "use_teacher_free_features": false,
    "uses_current_state_features": false,
    "use_two_branch_residual_core": false,
    "feature_aware_state_branch_tangents": false,
    "transport_scope": "train_only",
    "transport_steps": 2,
    "bootstrap_integrator": "rk2",
    "bootstrap_substeps": 4,
    "selection_metric": "val_configured_transported_final_energy",
    "selection_metric_source": "val_metric",
    "report_metric_source": "test_metric",
    "acceptance_contract": "mechanism_first"
  },
  "psi_network": {
    "hidden_dims": [
      128
    ],
    "weight_scale": 0.01,
    "eta_w": 0.01,
    "eta_b": 0.01,
    "psi_init_seed": 1
  },
  "run": {
    "run_seed": 1,
    "model_init_seed": 1,
    "batch_order_seed": 1,
    "epochs": 12,
    "batch_size": 128,
    "shuffle_batches": true,
    "output_layout": "run_id_subdir"
  }
}