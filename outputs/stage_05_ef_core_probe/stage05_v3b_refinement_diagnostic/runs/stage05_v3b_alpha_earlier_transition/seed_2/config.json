    "test_fraction": 0.15,
    "data_seed": 2
  },
  "model": {
    "layer_dims": [
      64,
      16,
      10
    ],
    "hidden_activation": "tanh",
    "output_activation": "identity",
    "weight_scale": 0.05,
    "sigma2": 1.0,
    "eta_x": 0.1,
    "eta_w": 0.02,
    "eta_b": 0.02,
    "eval_steps": 15,
    "state_init": "forward"
  },
  "transport": {
    "candidate_name": "stage05_v3b_trajectory_curriculum_contract",
    "teacher_free": true,
    "uses_teacher_artifacts": false,
    "transport_family": "two_branch_residual_meanflow_core",
    "residual_identity_mode": "residual_corrected_meanflow",
    "energy_substrate": "baseline_pc_energy",
    "local_flow_definition": "exact_negative_hidden_state_gradient",
    "direct_anchor_source": "self_bootstrap_local_field",
    "psi_family": "two_branch_residual_local_flow_mlp",
    "velocity_parameterization": "u_psi = g_theta + q_psi(z_t, target_onehot, t, r) + d_psi(g_t, e_out_t, F_t)",
    "u_psi_input_contract": "u_psi = g_t + q_psi(concat([z_t, target_onehot, t, r])) + d_psi(concat([g_t, e_out_t, F_t]))",
    "residual_branch_structure": "two_branch",
    "m_traj_input_contract": "concat([z_t, target_onehot, t, r])",
    "m_state_input_contract": "concat([g_t, e_out_t, F_t])",
    "bootstrap_target_contract": "m_boot = ((Phi_LF_r(z_t; c) - z_t) / r) - g_t",
    "explicit_transport_drift_target_contract": "gbar_boot = avg local flow over the same bootstrap interval; d_boot = gbar_boot - g_t; q_boot = u_boot - gbar_boot",
    "trajectory_curriculum_target_contract": "u_curr_target = alpha * u_boot(z_t, alpha * r, t; c) + (1 - alpha) * u_hat(z_s_boot, r_s, s; c) [detached target side]",
    "residual_identity_target_contract": "m_id = r * D_T g_t + r * D_T m_traj + r * D_T m_state",
    "identity_loss_weight": 0.1,
    "lambda_drift": 1.0,
    "lambda_traj_curr": 0.1,
    "tangent_epsilon": 0.001,
    "lambda_id_warmup_epochs": 3,
    "lambda_id_ramp_epochs": 3,
    "alpha_floor": 0.25,
    "alpha_warmup_epochs": 1,
    "alpha_ramp_epochs": 1,
    "trajectory_curriculum_enabled": true,
    "trajectory_curriculum_schedule_identity": "warmup_sigmoid_to_alpha_floor",
    "no_teacher_dependency_in_target_construction": true,
    "use_teacher_free_features": true,
    "uses_current_state_features": true,
    "use_two_branch_residual_core": true,
    "explicit_transport_drift_decomposition_enabled": true,
    "pairwise_deltas_vs_stage05_v3a_reference": {
      "status": "pending_real_fixed_budget_v2_vs_v3a_vs_v3b_comparison",
      "reference_candidate_name": "stage05_v3a_explicit_transport_drift_contract"
    },
    "feature_aware_state_branch_tangents": true,
    "transport_scope": "train_only",
    "transport_steps": 2,
    "bootstrap_integrator": "rk2",
    "bootstrap_substeps": 4,
    "selection_metric": "val_configured_transported_final_energy",
    "selection_metric_source": "val_metric",
    "report_metric_source": "test_metric",
    "acceptance_contract": "mechanism_first",
    "pairwise_deltas_vs_stage05_v2_reference": {
      "status": "pending_real_fixed_budget_v2_vs_v3a_vs_v3b_comparison",
      "reference_candidate_name": "stage05_v2_two_branch_corrected_residual_meanflow_core"
    },
    "gap_closure_decision": "pending_real_fixed_budget_v2_vs_v3a_vs_v3b_comparison",
    "recommended_next_move": "run_fixed_budget_v2_vs_v3a_vs_v3b_comparison"
  },
  "psi_network": {
    "hidden_dims": [
      128
    ],
    "weight_scale": 0.01,
    "eta_w": 0.01,
    "eta_b": 0.01,
    "psi_init_seed": 2
  },
  "run": {
    "run_seed": 2,
    "model_init_seed": 2,
    "batch_order_seed": 2,
    "epochs": 1536,
    "batch_size": 128,
    "shuffle_batches": true,
    "output_layout": "run_id_subdir"
  }
}